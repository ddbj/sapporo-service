# NIG dev environment (sapporo-dev.ddbj.nig.ac.jp, a012:1122)
# Usage: cp env.dev .env && podman-compose up -d

SAPPORO_ENV=dev
SAPPORO_VERSION=2.2.4

# --- Sapporo service ---
SAPPORO_PORT=1122
SAPPORO_DEBUG=True
SAPPORO_BASE_URL=https://sapporo-dev.ddbj.nig.ac.jp/ga4gh/wes/v1
SAPPORO_URL_PREFIX=/ga4gh/wes/v1
SAPPORO_ALLOW_ORIGIN=*
# Append additional "podman run" flags for inner workflow engine containers.
# Example: SAPPORO_EXTRA_PODMAN_ARGS="-v /lustre9/open/shared:/lustre9/open/shared:ro"
SAPPORO_EXTRA_PODMAN_ARGS=

# --- Slurm (read by scripts/update_slurm_env.sh) ---
SLURM_MASTER_NODE_HOSTNAME=a039
SLURM_MASTER_NODE_PORT=6820
SLURM_TOKEN_LIFESPAN=604800
SLURM_PARTITION=test
SLURM_CPUS_PER_TASK=4
SLURM_MEMORY_PER_CPU=8000
